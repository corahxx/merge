    # 字段映射表（告诉系统哪个词属于哪个字段）
    FIELD_MAPPING = {
        "运营商名称": list(OPERATOR_NICKNAMES.keys()) + ["运营商", "公司", "哪家", "品牌", "品牌商"],
        "区县_中文": list(LOCATION_NICKNAMES.keys()) + ["地区", "区域", "地方", "城市", "省市"],
        "充电站位置": ["位置", "在哪", "地址", "地处", "哪里", "什么地方", "地点"],
        "充电站名称": ["充电站", "站点", "桩站", "场站", "站名"],
        "充电桩类型": list(PILE_TYPE_NICKNAMES.keys()) + ["类型", "哪种", "什么类型"],
        "充电开始时间": list(TIME_EXPRESSIONS.keys()) + ["什么时候", "时间", "日期", "何时", "哪天", "期间"],
        "充电桩编号": ["编号", "ID", "编码", "代码", "桩号"],
    }

    @classmethod
    def get_actual_value(cls, field: str, nickname: str) -> str:
        """根据字段和昵称返回真实值"""
        if field == "运营商名称":
            return cls.OPERATOR_NICKNAMES.get(nickname, nickname)
        elif field == "区县_中文":
            return cls.LOCATION_NICKNAMES.get(nickname, nickname)
        elif field == "充电桩类型":
            return cls.PILE_TYPE_NICKNAMES.get(nickname, nickname)
        else:
            return nickname

    @classmethod
    def get_time_sql_hint(cls, time_expr: str) -> str:
        """
        获取时间表达式的SQL提示
        :param time_expr: 用户输入的时间表达式
        :return: SQL表达式或提示文本
        """
        return cls.TIME_EXPRESSIONS.get(time_expr, None)

    @classmethod
    def normalize_location(cls, location: str) -> str:
        """
        标准化地理位置表达
        :param location: 用户输入的地理位置
        :return: 标准化后的地理位置
        """
        # 先检查完整的匹配
        if location in cls.LOCATION_NICKNAMES:
            return cls.LOCATION_NICKNAMES[location]
        
        # 模糊匹配（包含关系）
        for key, value in cls.LOCATION_NICKNAMES.items():
            if key in location or location in key:
                return value
        
        return location

    @classmethod
    def normalize_operator(cls, operator: str) -> str:
        """
        标准化运营商名称
        :param operator: 用户输入的运营商名称
        :return: 标准化后的运营商名称
        """
        # 先检查完整的匹配
        if operator in cls.OPERATOR_NICKNAMES:
            return cls.OPERATOR_NICKNAMES[operator]
        
        # 模糊匹配（包含关系）
        for key, value in cls.OPERATOR_NICKNAMES.items():
            if key in operator or operator in key:
                return value
        
        return operator

    @classmethod
    def get_all_operators(cls) -> list:
        """获取所有标准运营商名称列表（去重）"""
        return sorted(list(set(cls.OPERATOR_NICKNAMES.values())))

    @classmethod
    def get_all_cities(cls) -> list:
        """获取所有城市列表"""
        cities = set()
        for value in cls.LOCATION_NICKNAMES.values():
            # 提取城市名（去掉区名）
            if "市" in value:
                city = value.split("市")[0] + "市"
                cities.add(city)
        return sorted(list(cities))
